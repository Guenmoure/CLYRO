# E2E test environment variables
# Copy to .env.test and fill in values

# Supabase project (can be a dedicated test project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — used ONLY in global-setup.ts to create test users
# NEVER commit the real value
E2E_SUPABASE_URL=https://your-project.supabase.co
E2E_SUPABASE_SERVICE_KEY=your-service-role-key

# API base URL (defaults to http://localhost:4000)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: override the web app base URL for tests
# BASE_URL=http://localhost:3000
