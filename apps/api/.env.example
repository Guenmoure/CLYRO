# CLYRO API — Environment Variables
# Copy to .env and fill in the values.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── ElevenLabs (Text-to-Speech) ───────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── fal.ai (Image + Video generation) ────────────────────────────────────────
FAL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_CREATOR=price_...
STRIPE_PRICE_STUDIO=price_...

# ── Moneroo (African payments) ────────────────────────────────────────────────
MONEROO_API_KEY=
MONEROO_WEBHOOK_SECRET=
MONEROO_SIGNATURE_HEADER=

# ── Resend (Transactional emails) ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── HeyGen (F5 AI Avatar Studio) ──────────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_WEBHOOK_SECRET=

# ── BullMQ Queue (REQUIRED in production) ────────────────────────────────────
# Without REDIS_URL the API runs pipelines inline (blocks event loop on big jobs).
# In production: provision a Redis instance (Upstash / Render Key-Value / etc.)
# and set REDIS_URL on BOTH clyro-api and clyro-worker.
REDIS_URL=

# Allow inline fallback when no worker is available?
# 'true'  → pipeline runs in API process (legacy, blocks event loop).
# 'false' → API returns 503 WORKER_UNAVAILABLE (fail-fast, recommended for prod
#           once clyro-worker + Redis are stable).
ALLOW_INLINE_FALLBACK=false

# Pipeline watchdog (kill long-running renders to free worker memory).
# Default = 1800000 (30 min). Increase for very long scripts (>5 min videos).
PIPELINE_TIMEOUT_MS=1800000

# ── Remotion Lambda (Motion + MotionDesign cloud rendering) ──────────────────
# OPTIONAL: 3-5× faster than local Chromium for long videos. Cost ~$0.01/video.
#
# Setup (once per AWS region):
#   npx remotion lambda policies validate
#   npx remotion lambda functions deploy --memory=3009 --timeout=240 --disk=2048
#   npx remotion lambda sites create apps/api/src/remotion/Root.tsx --site-name=clyro-motion
#
# Re-run `lambda sites create` after EVERY change to packages/video/src/
# (otherwise Lambda renders the old bundle while local renders the new one).
#
# Set USE_REMOTION_LAMBDA=false (or unset) to use the local Chromium renderer.
USE_REMOTION_LAMBDA=false
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-4-0-448-mem3009mb-disk2048mb-240sec
REMOTION_LAMBDA_SERVE_URL=https://remotionlambda-xxxxx.s3.eu-west-3.amazonaws.com/sites/clyro-motion/index.html

# ── Inter-service HMAC signing (routes /api/internal/*) ──────────────────────
# Generate with: openssl rand -hex 32
# MUST be identical across all services that call /api/internal/*
INTERNAL_HMAC_SECRET=

# ── Background Music (royalty-free, hosted on Supabase Storage or CDN) ───────
# Optional: leave empty to disable background music feature.
# Upload MP3 files to your storage and set the public URLs here.
MUSIC_AMBIENT_CALM_URL=
MUSIC_CORPORATE_URL=
MUSIC_EPIC_URL=
MUSIC_PLAYFUL_URL=
MUSIC_LOFI_URL=

# ── Server ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_URL=https://your-api.onrender.com
NODE_ENV=production
PORT=4000
