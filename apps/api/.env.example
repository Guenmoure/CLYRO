# CLYRO API — Environment Variables
# Copy to .env and fill in the values.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── ElevenLabs (Text-to-Speech) ───────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── fal.ai (Image + Video generation) ────────────────────────────────────────
FAL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STUDIO=price_...

# ── Moneroo (African payments) ────────────────────────────────────────────────
MONEROO_API_KEY=
MONEROO_WEBHOOK_SECRET=

# ── Resend (Transactional emails) ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Remotion Lambda (Video rendering) ────────────────────────────────────────
USE_REMOTION_LAMBDA=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-4-0-448-mem3008mb-disk2048mb-240sec
REMOTION_LAMBDA_SERVE_URL=https://remotionlambda-...s3.us-east-1.amazonaws.com/sites/clyro/index.html

# ── Background Music (royalty-free, hosted on Supabase Storage or CDN) ───────
# Optional: leave empty to disable background music feature.
# Upload MP3 files to your storage and set the public URLs here.
MUSIC_AMBIENT_CALM_URL=
MUSIC_CORPORATE_URL=
MUSIC_EPIC_URL=
MUSIC_PLAYFUL_URL=
MUSIC_LOFI_URL=

# ── Inter-service HMAC (routes /api/internal) ────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be the same value on all services that call /api/internal/*
INTERNAL_HMAC_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_URL=https://your-api.onrender.com
NODE_ENV=production
PORT=4000
